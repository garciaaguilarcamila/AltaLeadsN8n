    {
      "parameters": {
        "jsCode": "const todos = $input.all();\nconst maximo = 1;\nconst seleccionados = todos.slice(0, maximo);\n\nreturn seleccionados.map((item, index) => ({\n  json: {\n    nombre: item.json.nombre || '',\n    email: (item.json.email || '').toLowerCase().trim(),\n    telefono: (item.json.telefono || '').toString().replace(/\\s/g, ''),\n    empresa: item.json.empresa || '',\n    comercial: item.json.comercial || 'Sin asignar',\n    origen: item.json.origen || 'fuente_leads',\n    observaciones: item.json.observaciones || '',\n    _email_original: (item.json.email || '').toLowerCase().trim(),\n    _indice: index\n  }\n}));"
      },
