    {
      "parameters": {
        "jsCode": "// Combinar datos del lead existente con la actualización solicitada\nconst leadActual = $json;\nconst datosActualizacion = $('Validar Estado').first().json;\n\nconst ahora = new Date();\nconst pad = (n) => n.toString().padStart(2, '0');\nconst fechaAhora = `${ahora.getFullYear()}-${pad(ahora.getMonth()+1)}-${pad(ahora.getDate())} ${pad(ahora.getHours())}:${pad(ahora.getMinutes())}:${pad(ahora.getSeconds())}`;\n\n// Si no se especifica comercial en la actualización, mantener el anterior\nconst comercialFinal = datosActualizacion.comercial || leadActual.comercial || 'Sin asignar';\n\nreturn [{\n  json: {\n    // Datos para actualizar en Leads\n    id: leadActual.id,\n    email: leadActual.email,\n    nombre: leadActual.nombre,\n    estado_anterior: leadActual.estado,\n    nuevo_estado: datosActualizacion.nuevo_estado,\n    comercial: comercialFinal,\n    fecha_ultima_accion: fechaAhora,\n    notas: datosActualizacion.notas || '',\n    row_number: leadActual.row_number\n  }\n}];"
      },
