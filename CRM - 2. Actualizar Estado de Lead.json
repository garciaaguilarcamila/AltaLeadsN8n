    {
      "parameters": {
        "jsCode": "// Validar que el estado es uno de los permitidos\nconst estadosPermitidos = [\n  'nuevo',\n  'validado',\n  'contactado',\n  'pendiente',\n  'presupuestado',\n  'cerrado_ganado',\n  'cerrado_perdido'\n];\n\nconst datos = $json;\nconst estadoSolicitado = datos.nuevo_estado || '';\n\nif (!datos.id_lead) {\n  return [{ json: { valido: false, error: 'El campo id_lead es obligatorio' } }];\n}\n\nif (!estadoSolicitado) {\n  return [{ json: { valido: false, error: 'El campo nuevo_estado es obligatorio' } }];\n}\n\nif (!estadosPermitidos.includes(estadoSolicitado)) {\n  return [{ json: { \n    valido: false, \n    error: `Estado no válido: '${estadoSolicitado}'. Estados permitidos: ${estadosPermitidos.join(', ')}` \n  } }];\n}\n\nreturn [{ json: { \n  valido: true, \n  id_lead: datos.id_lead,\n  nuevo_estado: estadoSolicitado,\n  comercial: datos.comercial,\n  notas: datos.notas\n} }];"
      },
