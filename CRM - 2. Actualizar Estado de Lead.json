    {
      "parameters": {
        "jsCode": "const leadNuevo = $('Normalizar Datos').first().json;\nconst emailNuevo = (leadNuevo.email || '').toLowerCase().trim();\nconst telefonoNuevo = (leadNuevo.telefono || '').toString().replace(/\\s/g, '');\n\nlet leadsExistentes = [];\ntry {\n  leadsExistentes = $('Leer Todos los Leads').all();\n} catch(e) {\n  leadsExistentes = [];\n}\n\nlet esDuplicado = false;\nlet leadExistente = null;\n\nfor (const item of leadsExistentes) {\n  const emailExistente = (item.json['correo electrónico'] || item.json.email || '').toLowerCase().trim();\n  const telefonoExistente = (item.json['teléfono'] || item.json.telefono || '').toString().replace(/\\s/g, '');\n\n  if (emailNuevo && emailExistente && emailNuevo === emailExistente) {\n    esDuplicado = true;\n    leadExistente = item.json;\n    break;\n  }\n  if (telefonoNuevo && telefonoExistente && telefonoNuevo.length > 6 && telefonoNuevo === telefonoExistente) {\n    esDuplicado = true;\n    leadExistente = item.json;\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    esDuplicado: esDuplicado ? \"si\" : \"no\",\n    leadExistente: leadExistente,\n    leadNuevo: leadNuevo\n  }\n}];"
      },
      "id": "7c4d9c69-1a9d-4d8d-a936-e8d1a2783fc8",
      "name": "Comprobar Duplicados",
