      "parameters": {
        "jsCode": "// Generar ID único para el nuevo lead\nconst ahora = new Date();\nconst pad = (n) => n.toString().padStart(2, '0');\n\nconst fechaStr = `${ahora.getFullYear()}${pad(ahora.getMonth()+1)}${pad(ahora.getDate())}`;\nconst horaStr = `${pad(ahora.getHours())}${pad(ahora.getMinutes())}${pad(ahora.getSeconds())}`;\nconst random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');\n\nconst idLead = `LEAD-${fechaStr}-${horaStr}-${random}`;\n\nconst fechaAhora = ahora.toISOString().replace('T', ' ').substring(0, 19);\n\nconst lead = $json.leadNuevo;\n\nreturn [{\n  json: {\n    id: idLead,\n    nombre: lead.nombre || '',\n    email: lead.email || '',\n    telefono: lead.telefono || '',\n    empresa: lead.empresa || '',\n    estado: 'nuevo',\n    comercial: lead.comercial || 'Sin asignar',\n    fecha_alta: fechaAhora,\n    fecha_ultima_accion: fechaAhora,\n    observaciones: lead.observaciones || '',\n    origen: lead.origen || 'manual'\n  }\n}];"
      },
